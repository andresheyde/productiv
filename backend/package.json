{
  "name": "productiv-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node src/server.ts",
    "dev:watch": "node --watch src/server.ts",
    "db:migrate": "node src/scripts/db-migrate.ts",
    "db:ping": "node src/scripts/db-ping.ts",
    "db:reset:local": "node src/scripts/db-reset-local.ts",
    "test": "node --test \"src/**/*.test.ts\"",
    "test:local": "node --test \"src/**/*.integration.test.ts\"",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/features/assistant/assistant.prompts.ts' --test-coverage-include='src/features/planning/planning.prompts.ts' --test-coverage-include='src/features/planning/planning.service.ts' --test-coverage-include='src/features/planning/planning.types.ts' --test-coverage-include='src/features/planning/planning.validation.ts' --test-coverage-exclude='src/**/*.test.ts' --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.5"
  }
}
